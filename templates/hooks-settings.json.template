{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=\"$CLAUDE_FILE_PATH\"; if [[ \"$file\" == *.env || \"$file\" == *.env.* ]] && [[ \"$file\" != *.env.example ]]; then echo 'BLOCKED: Cannot edit .env files — modify these manually for safety' >&2; exit 1; fi"
          }
        ]
      }
    ]
  }
}
